{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:fix-visit-type": "prisma db execute --schema prisma/schema.prisma --file prisma/migrations/migrate_drag_visit_objects.sql",
    "db:analytics-fields": "prisma db execute --schema prisma/schema.prisma --file prisma/migrations/add_attempt_analytics_fields.sql",
    "db:level-owner": "prisma db execute --schema prisma/schema.prisma --file prisma/migrations/add_level_owner_teacher.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:backup-items": "tsx scripts/backup-items-dataset.ts",
    "db:restore-items": "tsx scripts/restore-items-dataset.ts",
    "db:backup-full": "scripts\\backup-database-docker.bat",
    "db:restore-full": "scripts\\restore-database-docker.bat",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
